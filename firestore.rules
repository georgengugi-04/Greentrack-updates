rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    match /farmers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }
    match /batches/{batchId} {
      // Anyone authenticated can read (for QR scanning)
      allow read: if request.auth != null;
      // Only the farmer who owns it can write
      allow create: if request.auth.uid == request.resource.data.farmerId;
      allow update, delete: if request.auth.uid == resource.data.farmerId;
    }
  }
}
